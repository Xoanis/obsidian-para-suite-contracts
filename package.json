{
  "name": "obsidian-para-suite-contracts",
  "version": "0.3.0",
  "private": false,
  "description": "Shared public API contracts for the distributed Obsidian plugin workspace",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./telegram": {
      "types": "./dist/telegram.d.ts",
      "import": "./dist/telegram.js"
    },
    "./para-core": {
      "types": "./dist/para-core.d.ts",
      "import": "./dist/para-core.js"
    },
    "./finance-intake": {
      "types": "./dist/finance-intake.d.ts",
      "import": "./dist/finance-intake.js"
    },
    "./email-provider": {
      "types": "./dist/email-provider.d.ts",
      "import": "./dist/email-provider.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "telegram": [
        "dist/telegram.d.ts"
      ],
      "para-core": [
        "dist/para-core.d.ts"
      ],
      "finance-intake": [
        "dist/finance-intake.d.ts"
      ],
      "email-provider": [
        "dist/email-provider.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "check": "node ./node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "build": "node ./node_modules/typescript/bin/tsc -p tsconfig.build.json",
    "release:check": "npm pack --dry-run",
    "prepare": "npm run build",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "obsidian": "*"
  },
  "devDependencies": {
    "@types/node": "^22.13.11",
    "obsidian": "^1.8.7",
    "typescript": "^5.8.2"
  },
  "license": "MIT"
}
